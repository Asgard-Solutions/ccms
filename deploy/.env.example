# ── ChiroPro/CCMS blue/green — VPS environment ──────────────────────────────
# Copy to `/opt/chiropro/.env` on the VPS and fill in real values.
# NEVER commit the real .env to git.
#
# Verified against the repo: the backend HARD-REQUIRES exactly four vars at boot
# (MONGO_URL, DB_NAME, JWT_SECRET, DATA_ENCRYPTION_KEY). Redis + all third-party
# integrations are non-fatal (features degrade gracefully if unset). Seeding runs
# automatically & idempotently on startup — no separate migrate step needed.

# --- Container registry (GHCR) ---
BACKEND_IMAGE_REPO=ghcr.io/asgard-solutions/chiropro-backend
FRONTEND_IMAGE_REPO=ghcr.io/asgard-solutions/chiropro-frontend

# ============================================================================
# REQUIRED — the backend refuses to start without these four.
# ============================================================================
MONGO_URL=mongodb://chiro:change_me_strong_password@chiro_mongo:27017/chiropro?authSource=admin
DB_NAME=chiropro
# 🔐 JWT_SECRET: sign session tokens. >=32 chars.  openssl rand -hex 32
JWT_SECRET=change_me_generate_a_64_char_hex_secret
# 🔐 DATA_ENCRYPTION_KEY: encrypts PHI at rest. >=32 chars.  openssl rand -hex 32
#    ⚠️ MUST stay CONSTANT forever and be IDENTICAL for blue & green. If it ever
#    changes, previously-encrypted patient data becomes UNRECOVERABLE. Back it up.
DATA_ENCRYPTION_KEY=change_me_generate_a_64_char_hex_secret

# --- Shared MongoDB (docker-compose.infra.yml) ---
MONGO_ROOT_USER=chiro
MONGO_ROOT_PASSWORD=change_me_strong_password

# --- Shared Redis (recommended: enables cross-instance rate-limit + cache) ---
REDIS_PASSWORD=change_me_strong_redis_password
REDIS_URL=redis://:change_me_strong_redis_password@chiro_redis:6379/0

# --- Production posture ---
APP_ENV=production
# Locks CORS to this origin and enables Secure cookies. Must be HTTPS.
FRONTEND_URL=https://adjustpro.io
# Number of reverse proxies in front of the backend (host Nginx = 1; add +1 if
# Cloudflare/another LB sits in front). Ensures real client IPs for rate-limit/audit.
TRUSTED_PROXY_COUNT=1
# Explicit admin seed password (don't ship the default in prod).
ADMIN_PASSWORD=change_me_admin_password
MFA_ISSUER=AdjustPro

# --- Local disk paths (mounted shared volume /opt/chiropro/data → /app/data) ---
# Exports (CSV/PDF) and local PHI storage live here and are SHARED across colours
# + persisted across deploys via the bind mount added by deploy.sh.
EXPORT_DIR=/app/data/exports
EXPORT_TTL_HOURS=24
STORAGE_ROOT=/app/data/storage

# ============================================================================
# OPTIONAL integrations — set to enable the matching features (all non-fatal).
# ============================================================================
# EMERGENT_LLM_KEY=      # AI features + Emergent object storage (patient docs/media)
# STRIPE_API_KEY=
# HELCIM_API_TOKEN=      # payments / scheduled charges
# TWILIO_ACCOUNT_SID= / TWILIO_AUTH_TOKEN= / TWILIO_FROM_NUMBER=   # SMS
# RESEND_API_KEY=        # email
# GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=                        # Google auth

# --- Deployment behaviour ---
PUBLIC_URL=https://adjustpro.io
# Seeding is automatic on backend startup, so leave this EMPTY unless you add a
# bespoke one-off migration script (see deploy/db/README.md).
MIGRATE_CMD=
BACKEND_HEALTH_PATH=/api/health
FRONTEND_HEALTH_PATH=/healthz
HEALTH_TIMEOUT_SECONDS=150

# --- Encrypted pre-deploy backup (Mongo + /data) ---
# 🔐 Passphrase used to AES-256 encrypt backups. Generate: openssl rand -hex 32
#    Store it OUTSIDE the VPS. Without it, backups are skipped (never written unencrypted).
BACKUP_PASSPHRASE=
BACKUP_BEFORE_DEPLOY=true     # run an encrypted backup before each deploy
BACKUP_REQUIRED=true          # abort the deploy if that backup fails
BACKUP_RETENTION=7            # keep newest N of each archive type

# --- Post-switch smoke test (auto-rollback on failure) ---
RUN_SMOKE_TEST=true
# Comma-separated unauthenticated paths hit through the live edge after cutover.
SMOKE_PATHS=/api/health,/api/,/
# SMOKE_BASE_URL=              # defaults to PUBLIC_URL
